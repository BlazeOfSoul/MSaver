{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "JwtSettings": {
    "Key": "",
    "Issuer": "MSaver",
    "Audience": "MSaverFrontend",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 30
  },
  "ExchangeRateApi": {
    "ApiKey": "",
    "BaseUrl": "https://v6.exchangerate-api.com/v6/",
    "CacheDurationHours": 24,
    "TimeoutSeconds": 10
  },
  "Cors": {
    "FrontendOrigin": "http://localhost:4200"
  }
}
